# VITE_GEMINI_API_KEY: API key for online mode.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_OFFLINE_GEMMA_API_KEY: Optional dedicated key for offline toggle mode.
# If blank, the app falls back to VITE_GEMINI_API_KEY.
VITE_OFFLINE_GEMMA_API_KEY=""

# Model used while online toggle is enabled.
VITE_ONLINE_MODEL="gemini-2.5-flash"

# Model used while offline toggle is enabled (API-backed Gemma 4 mode).
VITE_OFFLINE_MODEL="gemma-4-31b-it"

# VITE_BASE_URL: The base sub-path for GitHub Pages.
# If the site is at https://<user>.github.io/<repo>/, set this to /<repo>/
# Leave blank (or /) for a custom domain or root deployment.
VITE_BASE_URL="/"
